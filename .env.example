# Copy this file to `.env.local` and fill in real values.

# ── MQTT (browser / WebSocket) ──────────────────────────────────────────────
# Browsers speak MQTT only over WebSocket — the URL MUST be ws:// or wss://.
# Brokers expose a dedicated WS port (EMQX/Mosquitto default 8083=ws, 8084=wss).
NEXT_PUBLIC_MQTT_URL=ws://localhost:8083/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_CLIENT_ID=kcf-mc-web
NEXT_PUBLIC_MQTT_RECONNECT_MS=4000
